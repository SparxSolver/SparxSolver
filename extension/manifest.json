{
  "manifest_version": 3,
  "name": "SparxSolver",
  "description": "Sparx Maths, Unlocked.",
  "version": "1.3.0",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://sparxmaths.uk/*",
    "https://www.sparxmaths.uk/*",
    "https://sparx-learning.com/*",
    "https://*.sparx-learning.com/*",
    "https://api.sparx-learning.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sparxmaths.uk/*",
        "https://www.sparxmaths.uk/*",
        "https://sparx-learning.com/*",
        "https://*.sparx-learning.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icon.png"
      ],
      "matches": [
        "https://sparxmaths.uk/*",
        "https://www.sparxmaths.uk/*",
        "https://sparx-learning.com/*",
        "https://*.sparx-learning.com/*"
      ]
    },
    {
      "resources": [
        "bundle-1.js"
      ],
      "matches": [
        "https://sparxmaths.uk/*",
        "https://www.sparxmaths.uk/*",
        "https://sparx-learning.com/*",
        "https://*.sparx-learning.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_security_policy": {
    "extension_page": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
